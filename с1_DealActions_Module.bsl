#Область ПрограммныйИнтерфейс

// Возвращает текущий UF_CRM_ACTIONID сделки из Bitrix24 через API Golos.
//
// Параметры:
//  ИдентификаторСделкиБ24 - Число, Строка - ID сделки в CRM (B24_ID).
//
// Возвращаемое значение:
//  Число - ACTIONID из B24 (0 если поле пустое);
//  Неопределено - ошибка HTTP, токена, разбора JSON или ACTIONID = null в ответе.
//
Функция ПолучитьAPIActionID(ИдентификаторСделкиБ24) Экспорт
	
	ИдентификаторСделкиСтрокой = НормализоватьИдентификаторСделкиБ24(ИдентификаторСделкиБ24);
	Если ПустаяСтрока(ИдентификаторСделкиСтрокой) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Настройки = НастройкиПодключенияActionID();
	ПутьЗапроса = "/api/crm/deal/" + ИдентификаторСделкиСтрокой + "/action-id?token=" + Настройки.Токен;
	
	ОтветHTTP = ВыполнитьHTTPЗапросGET(Настройки, ПутьЗапроса);
	Если ОтветHTTP = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		ЗаписатьСобытиеActionID(УровеньЖурналаРегистрации.Предупреждение,
			СтрШаблон("action-id: HTTP %1 для сделки B24 %2", ОтветHTTP.КодСостояния, ИдентификаторСделкиСтрокой),
			ОтветHTTP.Тело);
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат РазобратьActionIDИзТелаОтвета(ОтветHTTP.Тело, ИдентификаторСделкиСтрокой);
	
КонецФункции

// Решение по блок-схеме: применять ли изменения из сообщения RabbitMQ.
//
// Параметры:
//  MessageActionID - Число - ACTIONID из тела сообщения;
//  ActionID1C - Число - с1_ActionID в документе 1С;
//  ИдентификаторСделкиБ24 - Число - B24_ID;
//  ВызватьОповещениеПриОшибкеAPI - Булево - писать предупреждение в журнал при сбое API.
//
// Возвращаемое значение - Структура:
//   * Действие - Строка - "Применить" | "Игнорировать" | "ОшибкаAPI";
//   * Причина - Строка - текст для журнала/отладки;
//   * MessageActionID - Число;
//   * ActionID1C - Число;
//   * APIActionID - Число, Неопределено.
//
Функция РешениеПоПрименениюСообщения(MessageActionID, ActionID1C, ИдентификаторСделкиБ24, ВызватьОповещениеПриОшибкеAPI = Истина) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Действие", "Применить");
	Результат.Вставить("Причина", "");
	Результат.Вставить("MessageActionID", MessageActionID);
	Результат.Вставить("ActionID1C", ActionID1C);
	Результат.Вставить("APIActionID", Неопределено);
	
	// Шаг 1: 1CActionID > MessageActionID → ИГНОР
	Если ActionID1C > MessageActionID Тогда
		Результат.Действие = "Игнорировать";
		Результат.Причина = СтрШаблон(
			"1C ActionID (%1) больше ActionID сообщения (%2) — сообщение устарело для 1С",
			ActionID1C, MessageActionID);
		Возврат Результат;
	КонецЕсли;
	
	// Шаг 2: запрос APIActionID
	APIActionID = ПолучитьAPIActionID(ИдентификаторСделкиБ24);
	Результат.APIActionID = APIActionID;
	
	Если APIActionID = Неопределено Тогда
		Результат.Действие = "ОшибкаAPI";
		Результат.Причина = СтрШаблон(
			"Не удалось получить ACTIONID из B24 для сделки %1 — изменения не применяются",
			НормализоватьИдентификаторСделкиБ24(ИдентификаторСделкиБ24));
		
		Если ВызватьОповещениеПриОшибкеAPI Тогда
			ОповеститьОбОшибкеПолученияAPIActionID(ИдентификаторСделкиБ24, MessageActionID, ActionID1C);
		КонецЕсли;
		
		Возврат Результат;
	КонецЕсли;
	
	// Шаг 3: APIActionID > MessageActionID → ИГНОР (в B24 уже новее)
	Если APIActionID > MessageActionID Тогда
		Результат.Действие = "Игнорировать";
		Результат.Причина = СтрШаблон(
			"B24 ActionID (%1) больше ActionID сообщения (%2) — в CRM уже более новое действие",
			APIActionID, MessageActionID);
		Возврат Результат;
	КонецЕсли;
	
	// MessageActionID >= ActionID1C и MessageActionID >= APIActionID
	Результат.Действие = "Применить";
	Результат.Причина = СтрШаблон(
		"Сообщение актуально: Message=%1, 1C=%2, B24=%3",
		MessageActionID, ActionID1C, APIActionID);
	
	Возврат Результат;
	
КонецФункции

// Обёртка для обработчиков очереди B24→1C.
//
// Параметры:
//  MessageActionID - Число;
//  ActionID1C - Число - текущий с1_ActionID документа;
//  ИдентификаторСделкиБ24 - Число - B24_ID;
//  ДокументОбъект - ДокументОбъект - необязательно; при "Применить" обновляет с1_ActionID без записи.
//
// Возвращаемое значение - Структура:
//   * ПрерватьОбработку - Булево - Истина → выйти из обработчика (Возврат Ошибочка);
//   * Решение - Структура - результат РешениеПоПрименениюСообщения;
//   * ОбновленActionIDВПамяти - Булево.
//
Функция ОбработатьActionIDПередЗаписью(MessageActionID, ActionID1C, ИдентификаторСделкиБ24, ДокументОбъект = Неопределено) Экспорт
	
	Ответ = Новый Структура;
	Ответ.Вставить("ПрерватьОбработку", Ложь);
	Ответ.Вставить("ОбновленActionIDВПамяти", Ложь);
	
	Решение = РешениеПоПрименениюСообщения(MessageActionID, ActionID1C, ИдентификаторСделкиБ24, Истина);
	Ответ.Вставить("Решение", Решение);
	
	Если Решение.Действие = "Игнорировать" Тогда
		Ответ.ПрерватьОбработку = Истина;
		ЗаписатьСобытиеActionID(УровеньЖурналаРегистрации.Информация, Решение.Причина, "");
		Возврат Ответ;
	КонецЕсли;
	
	Если Решение.Действие = "ОшибкаAPI" Тогда
		Ответ.ПрерватьОбработку = Истина;
		Возврат Ответ;
	КонецЕсли;
	
	// Применить: фиксируем ActionID из сообщения (не подменяем на APIActionID)
	Если ДокументОбъект <> Неопределено
		И MessageActionID > ActionID1C Тогда
		
		ДокументОбъект.с1_ActionID = MessageActionID;
		Ответ.ОбновленActionIDВПамяти = Истина;
		
	ИначеЕсли ДокументОбъект <> Неопределено
		И MessageActionID = ActionID1C Тогда
		
		// уже совпадает
		Ответ.ОбновленActionIDВПамяти = Ложь;
		
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

// Извлекает MessageActionID из структуры сообщения API/Rabbit.
//
Функция MessageActionIDИзДанныхСообщения(ДанныеСообщения) Экспорт
	
	Если ДанныеСообщения = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеСообщения) <> Тип("Структура")
		И ТипЗнч(ДанныеСообщения) <> Тип("Соответствие") Тогда
		Возврат 0;
	КонецЕсли;
	
	ИмяПоля = "ACTIONID";
	Если ДанныеСообщения.Свойство(ИмяПоля) Тогда
		Возврат Число(ДанныеСообщения[ИмяПоля]);
	КонецЕсли;
	
	ИмяПоля = "ActionID";
	Если ДанныеСообщения.Свойство(ИмяПоля) Тогда
		Возврат Число(ДанныеСообщения[ИмяПоля]);
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Настройки HTTP для action-id (подставьте свои константы конфигурации).
Функция НастройкиПодключенияActionID() Экспорт
	
	Возврат НастройкиПодключенияActionIDПоУмолчанию();
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НастройкиПодключенияActionIDПоУмолчанию()
	
	Настройки = Новый Структура;
	Настройки.Вставить("Хост", "crm.golos.click");
	Настройки.Вставить("Порт", 443);
	Настройки.Вставить("ИспользоватьSSL", Истина);
	Настройки.Вставить("ТаймаутСекунд", 30);
	// Совпадает с PHP DEAL_ACTIONID_API_TOKEN / GolosDealActionIDAPI2025secure9p5m в текущей интеграции
	Настройки.Вставить("Токен", "GolosDealActionIDAPI2025secure9p5m");
	
	// TODO: заменить на чтение из константы/регистра, например:
	// Настройки.Токен = Константы.с1_ТокенDealActionIDAPI.Получить();
	
	Возврат Настройки;
	
КонецФункции

Функция НормализоватьИдентификаторСделкиБ24(ИдентификаторСделкиБ24)
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторСделкиБ24) Тогда
		Возврат "";
	КонецЕсли;
	
	Если ТипЗнч(ИдентификаторСделкиБ24) = Тип("Число") Тогда
		Возврат Формат(ИдентификаторСделкиБ24, "ЧГ=0");
	КонецЕсли;
	
	Возврат СокрЛП(Строка(ИдентификаторСделкиБ24));
	
КонецФункции

// Выполняет GET-запрос к API.
//
// Возвращаемое значение:
//  Структура - КодСостояния, Тело; Неопределено при исключении соединения.
//
Функция ВыполнитьHTTPЗапросGET(Настройки, ПутьЗапроса)
	
	ЗащищенноеСоединение = Неопределено;
	Если Настройки.ИспользоватьSSL Тогда
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	КонецЕсли;
	
	Таймаут = 30;
	Если Настройки.Свойство("ТаймаутСекунд") Тогда
		Таймаут = Настройки.ТаймаутСекунд;
	КонецЕсли;
	
	Попытка
		СоединениеHTTP = Новый HTTPСоединение(
			Настройки.Хост,
			Настройки.Порт,
			,
			,
			,
			Таймаут,
			ЗащищенноеСоединение);
	Исключение
		ЗаписатьСобытиеActionID(УровеньЖурналаРегистрации.Ошибка,
			"action-id: ошибка HTTP-соединения",
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Неопределено;
	КонецПопытки;
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	// Альтернатива query token — раскомментировать при переходе API на заголовок:
	// Заголовки.Вставить("X-API-Token", Настройки.Токен);
	
	ЗапросHTTP = Новый HTTPЗапрос(ПутьЗапроса, Заголовки);
	
	Попытка
		ОтветHTTP = СоединениеHTTP.ВызватьHTTPМетод("GET", ЗапросHTTP);
	Исключение
		ЗаписатьСобытиеActionID(УровеньЖурналаРегистрации.Ошибка,
			"action-id: ошибка вызова GET " + ПутьЗапроса,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Неопределено;
	КонецПопытки;
	
	Результат = Новый Структура;
	Результат.Вставить("КодСостояния", ОтветHTTP.КодСостояния);
	Результат.Вставить("Тело", ОтветHTTP.ПолучитьТелоКакСтроку());
	
	Возврат Результат;
	
КонецФункции

Функция РазобратьActionIDИзТелаОтвета(ТелоОтвета, ИдентификаторСделкиСтрокой)
	
	Если ПустаяСтрока(ТелоОтвета) Тогда
		ЗаписатьСобытиеActionID(УровеньЖурналаРегистрации.Предупреждение,
			"action-id: пустое тело ответа для сделки " + ИдентификаторСделкиСтрокой, "");
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеJSON = ПрочитатьJSONВСтруктуру(ТелоОтвета);
	Если ДанныеJSON = Неопределено Тогда
		ЗаписатьСобытиеActionID(УровеньЖурналаРегистрации.Ошибка,
			"action-id: не разобран JSON для сделки " + ИдентификаторСделкиСтрокой, ТелоОтвета);
		Возврат Неопределено;
	КонецЕсли;
	
	ЗначениеПоля = Неопределено;
	Если ДанныеJSON.Свойство("ACTIONID") Тогда
		ЗначениеПоля = ДанныеJSON.ACTIONID;
	ИначеЕсли ДанныеJSON.Свойство("ActionID") Тогда
		ЗначениеПоля = ДанныеJSON.ActionID;
	КонецЕсли;
	
	Если ЗначениеПоля = Неопределено Тогда
		ЗаписатьСобытиеActionID(УровеньЖурналаРегистрации.Предупреждение,
			"action-id: в ответе нет ACTIONID для сделки " + ИдентификаторСделкиСтрокой, ТелоОтвета);
		Возврат Неопределено;
	КонецЕсли;
	
	Если ЗначениеПоля = Null Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Число(ЗначениеПоля);
	
КонецФункции

Функция ПрочитатьJSONВСтруктуру(СтрокаJSON)
	
	// Используем существующий модуль конфигурации
	Попытка
		Возврат с1_ОбщийМодульВызовСервера.ПолучитьСтруктуруИзСтрокиJSON(СтрокаJSON);
	Исключение
	КонецПопытки;
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
		Данные = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Если ТипЗнч(Данные) = Тип("Структура") Тогда
			Возврат Данные;
		КонецЕсли;
		
		Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
			Результат = Новый Структура;
			Для Каждого КлючЗначение Из Данные Цикл
				Результат.Вставить(Строка(КлючЗначение.Ключ), КлючЗначение.Значение);
			КонецЦикла;
			Возврат Результат;
		КонецЕсли;
		
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ОповеститьОбОшибкеПолученияAPIActionID(ИдентификаторСделкиБ24, MessageActionID, ActionID1C)
	
	Текст = СтрШаблон(
		"Интеграция B24: не получен ACTIONID для сделки %1 (сообщение=%2, 1С=%3). Изменения не записаны.",
		НормализоватьИдентификаторСделкиБ24(ИдентификаторСделкиБ24),
		MessageActionID,
		ActionID1C);
	
	ЗаписатьСобытиеActionID(УровеньЖурналаРегистрации.Ошибка, Текст, "");
	
	// TODO: при необходимости — отправка в Telegram/e-mail через существующий механизм оповещений
	
КонецПроцедуры

Процедура ЗаписатьСобытиеActionID(Уровень, Комментарий, Данные)
	
	ИмяСобытия = "с1_DealActions.ActionID";
	ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень, , , Комментарий + ?(ПустаяСтрока(Данные), "", " | " + Данные));
	
КонецПроцедуры

#КонецОбласти
