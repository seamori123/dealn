// Замена блока ACTIONID в с1_Б24_СоздатьСделкуСНедвижимостьюПоДаннымИзAPI (~5985–5998)
// Требует общий модуль с1_DealActions — см. с1_DealActions_Module.bsl

MessageActionID = с1_DealActions.MessageActionIDИзДанныхСообщения(ДанныеЛида);

РезультатActionID = с1_DealActions.ОбработатьActionIDПередЗаписью(
	MessageActionID,
	ДокументСделкаН.с1_ActionID,
	B24_ID,
	ДокументСделкаН);

Если РезультатActionID.ПрерватьОбработку Тогда

	// При игноре устаревшего: продвинуть локальный счётчик до API (как у сделки К)
	Если РезультатActionID.Решение.Действие = "Игнорировать"
		И РезультатActionID.Решение.APIActionID <> Неопределено
		И РезультатActionID.Решение.APIActionID > ДокументСделкаН.с1_ActionID Тогда

		ДокументСделкаН.с1_ActionID = РезультатActionID.Решение.APIActionID;
		Попытка
			ДокументСделкаН.Записать();
		Исключение
			Ошибочка = Истина;
			ЗаписьЖурналаРегистрации("Ошибка записи сделки (ACTIONID)", УровеньЖурналаРегистрации.Ошибка, , ,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;

	КонецЕсли;

	Возврат Ошибочка;

КонецЕсли;

// Перед любым Записать / Записать(Проведение) при импорте из B24:
ДокументСделкаН.ДополнительныеСвойства.Вставить("с1_ЗагрузкаИзБитрикса", Истина);
